---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/assets/mascot/logo-hwc-2026.png" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="min-h-screen bg-primary-ark-blue text-white w-full overflow-x-hidden">
        <slot />
    </body>
</html>
