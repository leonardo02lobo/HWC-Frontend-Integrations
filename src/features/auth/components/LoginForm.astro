---
import LanguageSelect from "./LanguageSelect.tsx";
import GithubProfileInput from "./GithubProfileInput.tsx";
import AuthFeedbackModals from "./AuthFeedbackModals.tsx";
import { backendLanguages } from "../data";
---

<section class="w-full px-6 md:px-20 py-12 min-h-[70vh] flex flex-col items-center justify-center gap-8">

    <!-- Page Title with Division-style gradient line -->
    <div class="flex items-center gap-4 w-full max-w-5xl animate-on-scroll">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-primary-orange/40 to-primary-orange" />
        <h1 class="text-white text-2xl md:text-4xl font-zen-dots whitespace-nowrap">
            <span class="text-primary-orange">&lt;</span>Registro<span class="text-primary-orange">&nbsp;/&gt;</span>
        </h1>
        <div class="h-px flex-1 bg-gradient-to-l from-transparent via-primary-orange/40 to-primary-orange" />
    </div>

    <!-- How it works bar -->
    <div class="w-full max-w-5xl bg-[#141929] border border-gray-800/60 rounded-2xl p-5 transition-all duration-300 hover:border-gray-700/80 animate-on-scroll">
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
            <span class="text-white text-lg font-zen-dots shrink-0">
                <span class="text-primary-orange">$¿</span>Cómo funciona<span class="text-primary-orange">?.</span>
            </span>
            <div class="flex flex-col sm:flex-row gap-3 sm:gap-8">
                <p class="text-white/70 text-sm font-jetbrains">
                    <span class="text-primary-orange">1.</span> Completa el formulario
                </p>
                <p class="text-white/70 text-sm font-jetbrains">
                    <span class="text-primary-orange">2.</span> Serás categorizado
                </p>
                <p class="text-white/70 text-sm font-jetbrains">
                    <span class="text-primary-orange">3.</span> ¡Compite el 14 de Junio!
                </p>
            </div>
        </div>
    </div>

    <!-- Register Form Card -->
    <div id="register-form" class="auth-panel auth-panel--active w-full max-w-5xl bg-[#141929] border border-gray-800/60 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:border-gray-700/80 animate-on-scroll">
        <form method="post" action="" class="space-y-8">

            <!-- Two-column form sections -->
            <div class="flex flex-col md:flex-row gap-8">

                <!-- Profile Section -->
                <div class="flex-1 space-y-4">
                    <div class="pb-2">
                        <span class="text-white text-xl md:text-2xl font-zen-dots">
                            <span class="text-primary-orange">$</span>{"Datos de Perfil"}<span class="text-primary-orange">.</span>
                        </span>
                    </div>

                    <div class="space-y-4">
                        <label for="username" class="block space-y-1.5">
                            <span class="text-white font-medium text-sm flex items-center gap-1.5">
                                <span class="text-primary-orange">~</span>
                                Nombre de Usuario
                            </span>
                            <input
                                type="text"
                                id="username"
                                name="username"
                                required
                                placeholder="tu_username"
                                class="block w-full px-4 py-3 bg-primary-ark-blue/60 border border-gray-800/60 rounded-lg text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:border-primary-orange/40 transition duration-200 font-jetbrains text-sm"
                            />
                        </label>

                        <label for="name" class="block space-y-1.5">
                            <span class="text-white font-medium text-sm flex items-center gap-1.5">
                                <span class="text-primary-orange">~</span>
                                Nombre Completo
                            </span>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                required
                                placeholder="Juan Pérez"
                                class="block w-full px-4 py-3 bg-primary-ark-blue/60 border border-gray-800/60 rounded-lg text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:border-primary-orange/40 transition duration-200 font-jetbrains text-sm"
                            />
                        </label>

                        <label for="email" class="block space-y-1.5">
                            <span class="text-white font-medium text-sm flex items-center gap-1.5">
                                <span class="text-primary-orange">~</span>
                                Correo Electrónico
                                </span>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                placeholder="correo@ejemplo.com"
                                class="block w-full px-4 py-3 bg-primary-ark-blue/60 border border-gray-800/60 rounded-lg text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:border-primary-orange/40 transition duration-200 font-jetbrains text-sm"
                            />
                        </label>
                    </div>
                </div>

                <!-- Vertical divider on desktop -->
                <div class="hidden md:block w-px bg-gray-800/60"></div>

                <!-- Dev Config Section -->
                <div class="flex-1 space-y-4">
                    <div class="pb-2">
                        <span class="text-white text-xl md:text-2xl font-zen-dots">
                            <span class="text-primary-orange">$</span>{"Configuración de Desarrollo"}<span class="text-primary-orange">.</span>
                        </span>
                    </div>
                    <p class="text-white/40 text-xs font-jetbrains">
                        <span class="text-primary-orange">{"// "}</span>Específico para nivel de datos
                    </p>

                    <div class="space-y-4">
                        <div class="block space-y-1.5">
                            <span class="text-white font-medium text-sm flex items-center gap-1.5">
                                <span class="text-primary-orange">~</span>
                                ¿Cual es tu lenguaje de programación favorito?
                            </span>
                            <LanguageSelect client:load languages={backendLanguages} />
                        </div>

                        <div class="block space-y-1.5">
                            <span class="text-white font-medium text-sm flex items-center gap-1.5">
                                <span class="text-primary-orange">~</span>
                                Perfil de GitHub
                            </span>
                            <GithubProfileInput client:load />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <button
                type="submit"
                id="register-btn"
                class="w-full bg-primary-orange text-white font-bold py-4 px-6 rounded-lg transition-all duration-300 hover:scale-102 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:ring-offset-2 focus:ring-offset-[#141929] animate-glow-pulse font-zen-dots tracking-wide disabled:opacity-40 disabled:cursor-not-allowed disabled:animate-none disabled:hover:scale-100"
            >
                Registrar <span class="font-jetbrains">{"->"}</span>
            </button>
        </form>
    </div>

    <!-- Login Form Card -->
    <div id="login-form" class="auth-panel w-full max-w-5xl bg-[#141929] border border-gray-800/60 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:border-gray-700/80 animate-on-scroll">
        <form method="post" action="" class="space-y-8">
            <div class="max-w-md mx-auto space-y-4">
                <div class="pb-2">
                    <span class="text-white text-xl md:text-2xl font-zen-dots">
                        <span class="text-primary-orange">$</span>{"Iniciar Sesión"}<span class="text-primary-orange">.</span>
                    </span>
                </div>

                <label for="login-email" class="block space-y-1.5">
                    <span class="text-white font-medium text-sm flex items-center gap-1.5">
                        <span class="text-primary-orange">~</span>
                        Correo Electrónico
                    </span>
                    <input
                        type="email"
                        id="login-email"
                        name="login-email"
                        required
                        placeholder="correo@ejemplo.com"
                        class="block w-full px-4 py-3 bg-primary-ark-blue/60 border border-gray-800/60 rounded-lg text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:border-primary-orange/40 transition duration-200 font-jetbrains text-sm"
                    />
                </label>

                <label for="login-password" class="block space-y-1.5">
                    <span class="text-white font-medium text-sm flex items-center gap-1.5">
                        <span class="text-primary-orange">~</span>
                        Contraseña
                    </span>
                    <input
                        type="password"
                        id="login-password"
                        name="login-password"
                        required
                        placeholder="••••••••"
                        class="block w-full px-4 py-3 bg-primary-ark-blue/60 border border-gray-800/60 rounded-lg text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:border-primary-orange/40 transition duration-200 font-jetbrains text-sm"
                    />
                </label>
            </div>

            <!-- Submit Button -->
            <button
                type="submit"
                class="w-full bg-primary-orange text-white font-bold py-4 px-6 rounded-lg transition-all duration-300 hover:scale-102 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:ring-offset-2 focus:ring-offset-[#141929] animate-glow-pulse font-zen-dots tracking-wide"
            >
                Iniciar Sesión <span class="font-jetbrains">{"->"}</span>
            </button>
        </form>
    </div>

    <!-- Toggle auth mode link -->
    <div class="w-full max-w-5xl text-center animate-on-scroll">
        <a
            href="#"
            id="toggle-auth-mode"
            class="text-primary-orange underline underline-offset-4 hover:text-orange-400 transition font-jetbrains text-sm"
        >
            ¿Ya tienes usuario y contraseña? Inicia sesión
        </a>
    </div>

    <AuthFeedbackModals client:load />
</section>

<script>
    import "../type";

    const btn = document.getElementById("register-btn") as HTMLButtonElement;
    window.addEventListener("github-status", ((e: CustomEvent<string>) => {
        const status = e.detail;
        btn.disabled = status === "loading" || status === "invalid";
    }) as EventListener);
</script>
