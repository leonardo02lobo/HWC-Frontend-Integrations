---
import { backendLanguages } from "./../data.ts";
import AuthFeedbackModals from "./AuthFeedbackModals";
---

<div class="bg-gray-900 flex items-center justify-center px-4 py-8">
    <div
        class="bg-gray-800 rounded-2xl shadow-2xl max-w-4xl w-full flex flex-col overflow-hidden"
    >
        <h1
            class="text-3xl font-bold text-white text-center mb-8 mt-8 flex justify-center"
        >
            <span class="text-primary-orange">&lt;</span>
            <span>Registro de Participante</span>
            <span class="text-primary-orange">/&gt;</span>
        </h1>

        <p class="text-center text-gray-300 px-8 pb-2">
            <a
                href="#"
                id="toggle-auth-mode"
                class="text-primary-orange underline underline-offset-4 hover:text-orange-400 transition"
            >
                ¿Ya tienes usuario y contraseña? Inicia sesión
            </a>
        </p>

        <div class="flex flex-col md:flex-row">
            <div class="w-full md:w-1/2 p-8">
                <div class="relative min-h-[780px]">
                    <form
                        method="post"
                        action=""
                        class="space-y-6 auth-panel auth-panel--active"
                        id="register-form"
                    >
                        <div class="space-y-4">
                            <h2 class="text-xl font-semibold text-white pb-2">
                                [Datos de Perfil]
                            </h2>

                            <div class="space-y-3">
                                <label for="username" class="block">
                                    <span class="text-white font-medium"
                                        >Nombre de Usuario <span
                                            class="text-gray-400">(Username)</span
                                        ></span
                                    >
                                    <input
                                        type="text"
                                        id="username"
                                        name="username"
                                        required
                                        class="mt-1 block w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:border-transparent transition duration-200"
                                    />
                                </label>

                                <label for="name" class="block">
                                    <span class="text-white font-medium"
                                        >Nombre Completo <span class="text-gray-400"
                                            >(Name)</span
                                        ></span
                                    >
                                    <input
                                        type="text"
                                        id="name"
                                        name="name"
                                        required
                                        class="mt-1 block w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:border-transparent transition duration-200"
                                    />
                                </label>

                                <label for="email" class="block">
                                    <span class="text-white font-medium"
                                        >Correo Electrónico <span
                                            class="text-gray-400">(Mail)</span
                                        ></span
                                    >
                                    <input
                                        type="email"
                                        id="email"
                                        name="email"
                                        required
                                        class="mt-1 block w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:border-transparent transition duration-200"
                                    />
                                </label>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <h2
                                class="text-xl font-semibold text-primary-orange border-b border-primary-orange pb-2"
                            >
                                [Configuracion de Desarrollo]
                            </h2>
                            <p class="text-gray-400 text-sm">
                                (Especifico para nivel datos)
                            </p>

                            <div class="space-y-3">
                                <label for="language" class="block">
                                    <span class="text-white font-medium"
                                        >Lenguaje de Programación <span
                                            class="text-gray-400"
                                            >(Programming Language)</span
                                        ></span
                                    >
                                    <select
                                        id="language"
                                        name="language"
                                        required
                                        class="mt-1 block w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-primary-orange focus:border-transparent transition duration-200"
                                    >
                                        <option value="" class="bg-gray-700"
                                            >Selecciona un lenguaje</option
                                        >
                                        {
                                            backendLanguages.map((lang: string) => (
                                                <option
                                                    value={lang.toLowerCase()}
                                                    class="bg-gray-700"
                                                >
                                                    {lang}
                                                </option>
                                            ))
                                        }
                                    </select>
                                </label>

                                <label for="github" class="block">
                                    <span class="text-white font-medium"
                                        >Perfil de GitHub <span
                                            class="text-gray-400"
                                            >(GitHub Profile)</span
                                        ></span
                                    >
                                    <input
                                        type="url"
                                        id="github"
                                        name="github"
                                        required
                                        class="mt-1 block w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:border-transparent transition duration-200"
                                    />
                                </label>
                            </div>
                        </div>

                        <button
                            type="submit"
                            class="w-full bg-primary-orange hover:bg-orange-600 text-white font-bold py-4 px-6 rounded-lg transition duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:ring-offset-2 focus:ring-offset-gray-800"
                        >
                            [Registrar -&gt;]
                        </button>
                    </form>

                    <form
                        method="post"
                        action=""
                        class="space-y-6 auth-panel"
                        id="login-form"
                    >
                        <div class="space-y-4">
                            <h2
                                class="text-xl font-semibold text-primary-orange border-b border-primary-orange pb-2"
                            >
                                [Inicio de Sesión]
                            </h2>
                            <p class="text-gray-400 text-sm">
                                Ingresa tus credenciales para continuar
                            </p>

                            <div class="space-y-3">
                                <label for="login-email" class="block">
                                    <span class="text-white font-medium"
                                        >Correo Electrónico <span
                                            class="text-gray-400">(Mail)</span
                                        ></span
                                    >
                                    <input
                                        type="email"
                                        id="login-email"
                                        name="login-email"
                                        required
                                        class="mt-1 block w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:border-transparent transition duration-200"
                                    />
                                </label>

                                <label for="login-password" class="block">
                                    <span class="text-white font-medium"
                                        >Contraseña <span class="text-gray-400"
                                            >(Password)</span
                                        ></span
                                    >
                                    <input
                                        type="password"
                                        id="login-password"
                                        name="login-password"
                                        required
                                        minlength="6"
                                        class="mt-1 block w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:border-transparent transition duration-200"
                                    />
                                </label>
                            </div>
                        </div>

                        <button
                            type="submit"
                            class="w-full bg-primary-orange hover:bg-orange-600 text-white font-bold py-4 px-6 rounded-lg transition duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-orange focus:ring-offset-2 focus:ring-offset-gray-800"
                        >
                            [Iniciar sesión -&gt;]
                        </button>
                    </form>
                </div>
            </div>
            <div class="hidden md:flex items-center justify-center py-8">
                <img
                    src="/assets/login/fondo_login.png"
                    alt="Logo HWC 2026"
                    class="w-full h-full object-cover rounded-2xl"
                />
            </div>
        </div>
    </div>
</div>

<AuthFeedbackModals client:load />

<script src="./../type.ts"></script>

<style>
    .auth-panel {
        position: absolute;
        inset: 0;
        opacity: 0;
        transform: translateX(32px);
        pointer-events: none;
        z-index: 0;
        transition: opacity 300ms ease, transform 300ms ease;
    }

    .auth-panel--active {
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
        z-index: 1;
    }
</style>