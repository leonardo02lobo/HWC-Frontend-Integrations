---
import ExercisesDownloadCard from "./ExercisesDownloadCard.astro";
import ParticipantSidebar from "../../shared/components/ParticipantSidebar.astro";

const navigation = [
    { label: "Ejercicios", href: "/ejercicios", active: true },
    { label: "Mi Equipo", href: "/team" },
    { label: "Perfil", href: "/profile" },
];
---

<section class="exercises-shell">
    <div class="exercises-shell__sidebar">
        <ParticipantSidebar items={navigation} />
    </div>

    <div class="exercises-shell__main">
        <header class="exercises-shell__header">
            <h2 class="exercises-shell__title">
                <span class="text-primary-orange">&lt;</span>
                <span>Panel de Ejercicios</span>
                <span class="text-primary-orange">/&gt;</span>
            </h2>
            <p class="exercises-shell__subtitle">
                Visualización de instrucciones, descarga de materiales y entrega de solución.
            </p>
        </header>

        <div class="exercises-shell__content">
            <div class="exercises-shell__cards-grid">
                <div class="w-full">
                    <ExercisesDownloadCard
                        isPDF={true}
                        text="Ejercicios: PDF (Instrucciones Completas)"
                        description="Vea las instrucciones sobre el ejercicio"
                    />
                </div>
                <div class="w-full">
                    <ExercisesDownloadCard
                        isPDF={false}
                        text="Ejercicios: PDF (Informacion basica)"
                        description="En lo largo de las profundidades del océano se encuentran diversos ecosistemas"
                    />
                </div>
            </div>

            <div class="exercises-shell__submission">
                <h3 class="exercises-shell__submission-title">Entregar Solución</h3>
                <ExercisesDownloadCard
                    isPDF={false}
                    mode="add"
                    text="Agregar Ejercicio"
                    description="Ingrese la URL del repositorio"
                />
            </div>
        </div>
    </div>
</section>

<style>
    @reference "../../../styles/global.css";

    .exercises-shell {
        @apply mx-auto flex min-h-[calc(100vh-2rem)] w-full max-w-7xl flex-col gap-4 px-3 py-3 sm:px-4 md:gap-5 md:px-6 lg:flex-row lg:px-8;
    }

    .exercises-shell__sidebar {
        @apply lg:sticky lg:top-4 lg:h-[calc(100vh-2rem)] lg:w-[20rem] lg:shrink-0;
    }

    .exercises-shell__main {
        @apply flex min-w-0 flex-1 flex-col gap-4 rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_top,rgba(18,35,73,0.45),rgba(11,16,32,0.98)_58%)] p-4 shadow-[0_20px_80px_rgba(0,0,0,0.35)] sm:p-5 md:gap-5 md:p-6;
    }

    .exercises-shell__header {
        @apply flex flex-col gap-2;
    }

    .exercises-shell__title {
        @apply flex flex-wrap items-center gap-2 text-3xl text-white sm:text-4xl;
    }

    .exercises-shell__subtitle {
        @apply max-w-2xl text-sm text-white/60 md:text-base;
    }

    .exercises-shell__content {
        @apply flex flex-col gap-4 md:gap-5;
    }

    .exercises-shell__cards-grid {
        @apply grid grid-cols-1 gap-4 lg:grid-cols-2;
    }

    .exercises-shell__submission {
        @apply flex flex-col gap-3;
    }

    .exercises-shell__submission-title {
        @apply text-xl text-white;
    }
</style>
