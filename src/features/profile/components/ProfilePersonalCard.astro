---
import type { PersonalProfile } from "../data";

interface Props {
	profile: PersonalProfile;
}

const { profile } = Astro.props as Props;
---

<section
	class="relative flex flex-col gap-6 rounded-2xl border border-gray-800/60 bg-[#141929] p-5 transition-all duration-300 hover:border-gray-700/80 md:gap-7 md:p-6"
	aria-label="Datos personales del participante"
>
	<button
		type="button"
		data-profile-edit-trigger
		class="absolute right-4 top-4 inline-flex items-center gap-1.5 rounded-lg border border-gray-800/60 bg-primary-ark-blue/40 px-3 py-1.5 text-xs text-white/70 font-jetbrains transition-colors duration-200 hover:border-primary-orange/40 hover:bg-primary-orange/10 hover:text-primary-orange md:right-5 md:top-5"
		aria-label="Editar perfil"
	>
		<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
			<path d="M14 4l6 6-10 10H4v-6L14 4z" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
		Editar perfil
	</button>

	<!-- Hero stripe -->
	<header class="flex flex-col items-center gap-4 sm:flex-row sm:items-center sm:gap-6 sm:pr-32">
		<div class="relative shrink-0">
			<img
				src={profile.avatarUrl}
				alt={`Avatar de ${profile.name}`}
				class="h-20 w-20 rounded-full border-2 border-primary-orange/70 bg-white/5 object-cover ring-2 ring-primary-orange/10 ring-offset-2 ring-offset-[#141929] sm:h-24 sm:w-24"
				data-portrait-img
			/>
			<div
				class="absolute inset-0 hidden items-center justify-center rounded-full bg-black/50"
				data-portrait-loading
			>
				<svg class="h-7 w-7 animate-spin text-primary-orange" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
					<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
					<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
				</svg>
			</div>
		</div>

		<div class="flex min-w-0 flex-1 flex-col gap-2 text-center sm:text-left">
			<div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 sm:justify-start">
				<h3 class="truncate text-xl text-white font-zen-dots sm:text-2xl" data-profile-name>
					{profile.name}
				</h3>
				<span
					class="inline-flex items-center gap-1.5 rounded-full border border-primary-orange/40 bg-primary-orange/10 px-2.5 py-0.5 text-[11px] uppercase tracking-wider font-jetbrains text-primary-orange"
				>
					<span class="relative inline-flex h-1.5 w-1.5">
						<span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary-orange opacity-60"></span>
						<span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-primary-orange"></span>
					</span>
					<span data-profile-status>{profile.status}</span>
				</span>
			</div>

			<p class="text-sm text-white/50 font-jetbrains" data-profile-username>
				{profile.username}
			</p>

			<div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-xs font-jetbrains sm:justify-start">
				<button
					type="button"
					class="text-white/50 transition-colors duration-150 hover:text-primary-orange disabled:cursor-not-allowed disabled:opacity-50"
					data-portrait-change
				>
					↑ Cambiar foto
				</button>
				<span class="text-white/20">·</span>
				<button
					type="button"
					class="text-white/50 transition-colors duration-150 hover:text-rose-400 disabled:cursor-not-allowed disabled:opacity-50"
					data-portrait-delete
				>
					✕ Eliminar
				</button>
			</div>
		</div>
	</header>

	<input type="file" accept="image/png" class="hidden" data-portrait-input />

	<!-- Manifest-style inspector -->
	<dl class="grid grid-cols-1 gap-y-4 sm:grid-cols-2 sm:gap-x-6 lg:grid-cols-3">
		<div class="border-l border-primary-orange/30 pl-4">
			<dt class="flex items-center gap-1.5 text-[11px] uppercase tracking-wider text-white/40 font-jetbrains">
				<span class="text-primary-orange">~</span>
				Correo
			</dt>
			<dd class="mt-1 break-all text-sm text-white font-jetbrains" data-profile-email>
				{profile.email}
			</dd>
		</div>

		<div class="border-l border-primary-orange/30 pl-4">
			<dt class="flex items-center gap-1.5 text-[11px] uppercase tracking-wider text-white/40 font-jetbrains">
				<span class="text-primary-orange">~</span>
				Lenguaje
			</dt>
			<dd class="mt-1 text-sm text-white font-jetbrains" data-profile-language>
				{profile.programmingLanguage}
			</dd>
		</div>

		<div class="border-l border-primary-orange/30 pl-4">
			<dt class="flex items-center gap-1.5 text-[11px] uppercase tracking-wider text-white/40 font-jetbrains">
				<span class="text-primary-orange">~</span>
				GitHub
			</dt>
			<dd class="mt-1 text-sm font-jetbrains">
				<a
					href={`https://github.com/${profile.githubProfile}`}
					target="_blank"
					rel="noreferrer"
					class="inline-flex items-center gap-1.5 text-primary-orange transition-colors duration-200 hover:text-orange-400"
					data-profile-github
				>
					{profile.githubProfile}
					<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M6 3h7v7M13 3L7 9M11 9v4H3V5h4" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</a>
			</dd>
		</div>
	</dl>
</section>

<script>
	import { getCurrentUser } from "../../auth/services/auth.service";
	import { getPortrait, uploadPortrait, deletePortrait } from "../../portrait/data";
	import { dispatchApiError } from "../../../lib/events";

	const DEFAULT_AVATAR = "/assets/mascot/logo-hwc-2026.png";

	const img = document.querySelector("[data-portrait-img]") as HTMLImageElement | null;
	const loadingOverlay = document.querySelector("[data-portrait-loading]") as HTMLDivElement | null;
	const fileInput = document.querySelector("[data-portrait-input]") as HTMLInputElement | null;
	const changeButton = document.querySelector("[data-portrait-change]") as HTMLButtonElement | null;
	const deleteButton = document.querySelector("[data-portrait-delete]") as HTMLButtonElement | null;
	const editButton = document.querySelector("[data-profile-edit-trigger]") as HTMLButtonElement | null;
	const nameField = document.querySelector("[data-profile-name]") as HTMLSpanElement | null;
	const usernameField = document.querySelector("[data-profile-username]") as HTMLSpanElement | null;
	const emailField = document.querySelector("[data-profile-email]") as HTMLSpanElement | null;
	const languageField = document.querySelector("[data-profile-language]") as HTMLSpanElement | null;
	const githubField = document.querySelector("[data-profile-github]") as HTMLAnchorElement | null;
	const statusField = document.querySelector("[data-profile-status]") as HTMLSpanElement | null;
	let currentUserId: string | null = null;

	const setLoading = (isLoading: boolean) => {
		loadingOverlay?.classList.toggle("hidden", !isLoading);
		changeButton && (changeButton.disabled = isLoading);
		deleteButton && (deleteButton.disabled = isLoading);
	};

	const updateImage = (url: string) => {
		if (img) {
			img.src = url;
		}
	};

	const resetImage = () => {
		if (img) {
			img.src = DEFAULT_AVATAR;
		}
	};

	const normalizeGithubProfile = (profile: string) => {
		const trimmed = profile.trim();
		const match = trimmed.match(/(?:https?:\/\/)?(?:www\.)?github\.com\/([^/]+)/);
		return match?.[1] ?? trimmed;
	};

	const statusLabel = (status: number) => {
		if (status === 1) return "Activo";
		if (status === 0) return "Pendiente";
		if (status === -1) return "Sin categorizar";
		return `Estado ${status}`;
	};

	const setText = (element: HTMLElement | null, value: string | number | null | undefined, fallback = "No disponible") => {
		if (element) element.textContent = String(value ?? fallback);
	};

	const loadCurrentUser = async () => {
		try {
			const user = await getCurrentUser();
			const githubUsername = normalizeGithubProfile(user.github_profile);
			currentUserId = String(user.id);

			setText(nameField, user.name);
			setText(usernameField, user.username ? `@${user.username}` : null);
			setText(emailField, user.email);
			setText(languageField, user.programming_language);
			setText(statusField, statusLabel(user.status));

			if (githubField) {
				githubField.textContent = githubUsername || "No disponible";
				githubField.href = githubUsername ? `https://github.com/${githubUsername}` : "#";
			}

			if (user.portrait) {
				updateImage(user.portrait);
			}

			await loadPortrait(currentUserId);
		} catch (error) {
			console.error(error);
			window.location.href = "/register";
		}
	};

	const loadPortrait = async (userId: string) => {
		try {
			const payload = await getPortrait(userId);
			updateImage(payload.url);
		} catch {
			// Silently keep default avatar if no portrait exists
		}
	};

	loadCurrentUser();

	changeButton?.addEventListener("click", () => {
		fileInput?.click();
	});

	fileInput?.addEventListener("change", async () => {
		const file = fileInput?.files?.[0];
		if (!file) return;

		if (!file.type.match(/^image\/png$/)) {
			dispatchApiError("Solo se permiten archivos PNG");
			fileInput.value = "";
			return;
		}

		try {
			setLoading(true);
			const payload = await uploadPortrait(file, currentUserId ?? undefined);
			updateImage(payload.url);
		} catch (error) {
			const message = error instanceof Error ? error.message : "Error al subir la foto";
			dispatchApiError(message);
		} finally {
			setLoading(false);
			fileInput.value = "";
		}
	});

	deleteButton?.addEventListener("click", async () => {
		const confirmed = confirm("¿Eliminar foto de perfil?");
		if (!confirmed) return;

		try {
			setLoading(true);
			await deletePortrait(currentUserId ?? undefined);
			resetImage();
		} catch (error) {
			const message = error instanceof Error ? error.message : "Error al eliminar la foto";
			dispatchApiError(message);
		} finally {
			setLoading(false);
		}
	});

	editButton?.addEventListener("click", () => {
		const rawUsername = usernameField?.textContent?.trim() ?? "";
		window.dispatchEvent(
			new CustomEvent("profile:open-edit", {
				detail: {
					name: nameField?.textContent?.trim() ?? "",
					username: rawUsername.replace(/^@/, ""),
					email: emailField?.textContent?.trim() ?? "",
					language: languageField?.textContent?.trim() ?? "",
					github: githubField?.textContent?.trim() ?? "",
				},
			}),
		);
	});

	window.addEventListener("profile:updated", (event) => {
		const detail = (event as CustomEvent<{
			name?: string;
			username?: string | null;
			email?: string;
			language?: string | null;
			github?: string | null;
		}>).detail;
		if (!detail) return;

		if (detail.name) setText(nameField, detail.name);
		if (detail.username !== undefined) {
			setText(usernameField, detail.username ? `@${detail.username}` : null);
		}
		if (detail.email) setText(emailField, detail.email);
		if (detail.language !== undefined) {
			setText(languageField, detail.language ?? null);
		}
		if (detail.github !== undefined && githubField) {
			const handle = detail.github ?? "";
			githubField.textContent = handle || "No disponible";
			githubField.href = handle ? `https://github.com/${handle}` : "#";
		}
	});
</script>
