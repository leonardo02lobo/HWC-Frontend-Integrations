---
import ProfileAcademicFooter from "./ProfileAcademicFooter.astro";
import ProfileAcceptedTeamCard from "./ProfileAcceptedTeamCard.astro";
import ProfilePersonalCard from "./ProfilePersonalCard.astro";
import type { AcademicProfile, AcceptedTeamMember, PersonalProfile } from "../type";
import ParticipantSidebar from "../../shared/components/ParticipantSidebar.astro";

const personalProfile: PersonalProfile = {
	name: "Juan Pérez",
	username: "@juanperez_dev",
	email: "juan.perez@email.unet.edu.ve",
	avatarUrl: "/assets/mascot/logo-hwc-2026.png",
};

const academicProfile: AcademicProfile = {
	institution: "UNET",
	career: "Ingeniería Informática",
	level: "Junior",
};

const acceptedMembers: AcceptedTeamMember[] = [
	{ id: "1", name: "Juan Pérez" },
	{ id: "2", name: "María García" },
	{ id: "3", name: "Carlos Rodríguez" },
	{ id: "4", name: "" },
];

const navigation = [
	{ label: "Ejercicios", href: "/ejercicios" },
	{ label: "Mi Equipo", href: "/team" },
	{ label: "Perfil", href: "/profile", active: true },
	{ label: "Table Dashboard", href: "/tableDashboard" },
];
---

<section class="profile-shell">
    <div class="profile-shell__sidebar">
        <ParticipantSidebar items={navigation} />
    </div>
	<div class="profile-shell__main">
		<div class="profile-shell__content-grid">
			<div class="profile-shell__personal">
				<ProfilePersonalCard profile={personalProfile} />
			</div>
			<div class="profile-shell__team">
				<ProfileAcceptedTeamCard members={acceptedMembers} />
			</div>
		</div>
		<div class="profile-shell__footer">
			<ProfileAcademicFooter academic={academicProfile} />
		</div>
	</div>
</section>

<style>
	@reference "../../../styles/global.css";

    .profile-shell {
		@apply mx-auto flex min-h-[calc(100vh-2rem)] w-full max-w-7xl flex-col gap-4 px-3 py-3 sm:px-4 md:gap-5 md:px-6 lg:flex-row lg:px-8;
	}

	.profile-shell__sidebar {
		@apply lg:sticky lg:top-4 lg:h-[calc(100vh-2rem)] lg:w-[20rem] lg:shrink-0;
	}

	.profile-shell__main {
		@apply flex min-w-0 flex-1 flex-col gap-4 rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_top,rgba(24,34,66,0.95),rgba(11,16,32,0.98)_55%)] p-4 shadow-[0_20px_80px_rgba(0,0,0,0.35)] sm:p-5 md:gap-5 md:p-6;
	}

	.profile-shell__content-grid {
		@apply grid grid-cols-1 gap-4 xl:grid-cols-[minmax(0,22rem)_1fr] md:gap-5;
	}

	.profile-shell__personal {
		@apply min-w-0;
	}

	.profile-shell__team {
		@apply min-w-0;
	}

	.profile-shell__footer {
		@apply mt-auto;
	}
</style>
