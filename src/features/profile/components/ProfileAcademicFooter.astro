---
import type { AcademicProfile } from "../data";

interface Props {
	academic: AcademicProfile;
}

const { academic } = Astro.props as Props;
---

<footer class="bg-[#141929] border border-gray-800/60 rounded-2xl p-5 md:p-6 transition-all duration-300 hover:border-gray-700/80" aria-label="Información académica del participante">
	<h3 class="text-lg text-white font-zen-dots">
		<span class="text-primary-orange">~</span> Información Académica
	</h3>

	<div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
		<div class="rounded-lg border border-gray-800/60 bg-primary-ark-blue/60 px-4 py-3">
			<p class="text-xs uppercase tracking-wide text-white/40 font-jetbrains">Institución</p>
			<p class="mt-1 text-sm text-white font-jetbrains">{academic.institution}</p>
		</div>
		<div class="rounded-lg border border-gray-800/60 bg-primary-ark-blue/60 px-4 py-3">
			<p class="text-xs uppercase tracking-wide text-white/40 font-jetbrains">Carrera</p>
			<p class="mt-1 text-sm text-white font-jetbrains">{academic.career}</p>
		</div>
		<div class="rounded-lg border border-gray-800/60 bg-primary-ark-blue/60 px-4 py-3">
			<p class="text-xs uppercase tracking-wide text-white/40 font-jetbrains">Nivel</p>
			<p class="mt-1 text-sm text-primary-orange font-jetbrains">{academic.level}</p>
		</div>
	</div>
</footer>
