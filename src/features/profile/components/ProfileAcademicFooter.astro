---
import type { AcademicProfile } from "../data";

interface Props {
	academic: AcademicProfile;
}

const { academic } = Astro.props as Props;
---

<footer class="rounded-3xl border border-white/10 bg-[linear-gradient(180deg,rgba(21,31,58,0.95),rgba(11,16,32,0.99))] p-4 shadow-[0_16px_40px_rgba(0,0,0,0.28)] sm:p-5" aria-label="Información académica del participante">
	<h3 class="text-xl text-white sm:text-2xl">Información Académica (UNET)</h3>

	<div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
		<div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">
			<p class="text-xs uppercase tracking-wide text-white/55">Institución</p>
			<p class="mt-1 text-sm text-white">{academic.institution}</p>
		</div>
		<div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">
			<p class="text-xs uppercase tracking-wide text-white/55">Carrera</p>
			<p class="mt-1 text-sm text-white">{academic.career}</p>
		</div>
		<div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">
			<p class="text-xs uppercase tracking-wide text-white/55">Nivel</p>
			<p class="mt-1 text-sm text-white">{academic.level}</p>
		</div>
	</div>
</footer>
