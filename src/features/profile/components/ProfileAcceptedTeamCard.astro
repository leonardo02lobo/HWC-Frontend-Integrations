---
import type { AcceptedTeamMember } from "../data";

interface Props {
	members: AcceptedTeamMember[];
}

const { members } = Astro.props as Props;

const initialsOf = (name: string) =>
	name
		.split(/\s+/)
		.filter(Boolean)
		.map((part) => part[0]?.toUpperCase() ?? "")
		.slice(0, 2)
		.join("");
---

<section
	class="flex h-full flex-col gap-4 rounded-2xl border border-gray-800/60 bg-[#141929] p-5 transition-all duration-300 hover:border-gray-700/80 md:p-6"
	aria-label="Miembros del equipo que aceptaron invitación"
>
	<header class="flex items-start justify-between gap-3">
		<div class="flex flex-col gap-1">
			<h3 class="text-base text-white font-zen-dots sm:text-lg">
				<span class="text-primary-orange">~</span> Team Aceptado
			</h3>
			<p class="text-xs text-white/40 font-jetbrains">
				<span class="text-primary-orange">{"// "}</span>Solo invitaciones aceptadas
			</p>
		</div>
		<span class="rounded-md border border-primary-orange/30 bg-primary-orange/10 px-2 py-0.5 text-[11px] font-jetbrains text-primary-orange">
			{members.length}
		</span>
	</header>

	<ul class="flex flex-col gap-1.5">
		{
			members.map((member) => (
				<li>
					<a
						href={`/profile/${member.id}`}
						class="group flex items-center gap-3 rounded-lg border border-transparent px-2 py-2 transition-all duration-200 hover:border-primary-orange/30 hover:bg-primary-orange/[0.06]"
					>
						<span
							class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-primary-orange/50 bg-primary-orange/10 text-[11px] text-primary-orange font-zen-dots"
							aria-hidden="true"
						>
							{initialsOf(member.name)}
						</span>
						<span class="min-w-0 flex-1 truncate text-sm text-white font-jetbrains transition-colors duration-200 group-hover:text-primary-orange">
							{member.name}
						</span>
						<span class="inline-flex items-center gap-1 rounded-md border border-emerald-500/30 bg-emerald-500/10 px-2 py-0.5 text-[10px] text-emerald-300 font-jetbrains">
							<svg viewBox="0 0 16 16" class="h-2.5 w-2.5" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
								<path d="M3 8.5l3.5 3.5L13 4.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
							Aceptado
						</span>
					</a>
				</li>
			))
		}
	</ul>
</section>
