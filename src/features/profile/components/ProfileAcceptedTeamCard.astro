---
import type { AcceptedTeamMember } from "../data";

interface Props {
	members: AcceptedTeamMember[];
}

const { members } = Astro.props as Props;
---

<section class="flex h-full flex-col gap-4 bg-[#141929] border border-gray-800/60 rounded-2xl p-5 md:p-6 transition-all duration-300 hover:border-gray-700/80" aria-label="Miembros del equipo que aceptaron invitación">
	<header class="flex flex-col gap-2">
		<h3 class="text-lg text-white font-zen-dots">
			<span class="text-primary-orange">~</span> Team Aceptado
		</h3>
		<p class="text-sm text-white/40 font-jetbrains">
			Solo se muestran personas con invitación aceptada.
		</p>
	</header>

	<div class="grid grid-cols-1 gap-3 md:grid-cols-2">
		{members.map((member, index) => (
			<div class="flex flex-col gap-1 rounded-lg border border-gray-800/60 bg-primary-ark-blue/60 p-3">
				<span class="text-xs text-white/40 font-jetbrains">Miembro {index + 1}</span>
				<a
					href={`/profile/${member.id}`}
					class="text-sm text-primary-orange hover:text-orange-400 transition-colors duration-200 font-jetbrains"
				>
					{member.name}
				</a>
			</div>
		))}
	</div>
</section>
