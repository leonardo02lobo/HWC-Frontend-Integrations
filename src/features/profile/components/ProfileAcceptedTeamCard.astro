---
import type { AcceptedTeamMember } from "../data";

interface Props {
	members: AcceptedTeamMember[];
}

const { members } = Astro.props as Props;
---

<section class="flex flex-col gap-4 rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_top,rgba(24,34,66,0.9),rgba(11,16,32,0.98)_58%)] p-4 shadow-[0_18px_60px_rgba(0,0,0,0.3)] sm:p-5" aria-label="Miembros del equipo que aceptaron invitación">
	<header class="flex flex-col gap-2">
		<h2 class="flex flex-wrap items-center gap-2 text-2xl text-white sm:text-3xl">
			<span class="text-primary-orange">&lt;</span>
			<span>Team Aceptado</span>
			<span class="text-primary-orange">/&gt;</span>
		</h2>
		<p class="text-sm text-white/60">Solo se muestran personas con invitación aceptada.</p>
	</header>

	<div class="grid grid-cols-1 gap-3 md:grid-cols-2">
		{members.map((member, index) => (
			<label class="flex flex-col gap-2 rounded-2xl border border-white/10 bg-white/5 p-3" for={`accepted-member-${member.id}`}>
				<span class="text-sm text-white/70">Miembro {index + 1}</span>
				<a 
					href={`/profile/${member.id}`} 
					class="text-sm text-primary-orange hover:underline focus-visible:underline"
				>
					{member.name}
				</a>
			</label>
		))}
	</div>
</section>
