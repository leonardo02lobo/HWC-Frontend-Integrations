---
import Pdf from "../../../components/ui/Pdf.astro";
import Github from "../../../components/ui/Github.astro";
interface Props {
    isPDF: boolean;
    text: string;
    description: string;
    mode?: "download" | "add";
}
const { isPDF, text, description, mode = "download" } = Astro.props as Props;
---

<div
    class="flex flex-col gap-4 bg-[#141929] border border-gray-800/60 rounded-2xl p-5 md:p-6 transition-all duration-300 hover:border-gray-700/80"
    role="article"
    aria-label={text}
>
    {
        mode === "download" ? (
            <>
                <div class="flex items-start gap-3">
                    {isPDF && (
                        <div class="flex items-center justify-center w-10 h-10 rounded-lg">
                            <Pdf />
                        </div>
                    )}
                    <div class="min-w-0">
                        <h4 class="text-base md:text-lg text-white font-jetbrains">
                            {text}
                        </h4>
                        <p class="text-sm text-white/50 mt-1 font-jetbrains line-clamp-2">
                            {description}
                        </p>
                    </div>
                </div>

                <div class="h-px bg-gray-800/60" />

                <div class="flex items-center justify-between gap-3">
                    <p class="text-sm text-white/40 font-jetbrains line-clamp-2">
                        {isPDF ? "Archivo PDF disponible para descarga" : "Material de referencia"}
                    </p>
                    {isPDF ? (
                        <button
                            class="shrink-0 bg-primary-orange text-white text-sm px-4 py-2 rounded-lg hover:bg-orange-600 transition-all duration-200 font-jetbrains flex items-center gap-2"
                            aria-label={`Descargar ${text}`}
                            data-exercise-download
                        >
                            <svg class="hidden h-4 w-4 animate-spin" data-exercise-spinner xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                            </svg>
                            <span data-exercise-text>Descargar</span>
                        </button>
                    ) : null}
                </div>
            </>
        ) : (
            <>
                <div>
                    <h4 class="text-base md:text-lg text-white font-jetbrains">
                        {text}
                    </h4>
                    <p class="text-sm text-white/50 mt-1 font-jetbrains line-clamp-2">
                        {description}
                    </p>
                </div>

                <div class="h-px bg-gray-800/60" />

                <form class="w-full" id="form-repo">
                    <div class="flex flex-col sm:flex-row items-center gap-3 w-full">
                        <label
                            for="repo-url"
                            class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/5 shrink-0 cursor-pointer"
                            aria-hidden
                        >
                            <Github />
                        </label>
                        <input
                            id="repo-url"
                            name="repo-url"
                            type="url"
                            placeholder="https://github.com/usuario/repo"
                            class="flex-1 w-full px-4 py-2.5 rounded-lg border border-gray-800/60 bg-primary-ark-blue/60 text-white text-sm placeholder:text-white/25 focus:outline-none focus:ring-2 focus:ring-primary-orange/60 focus:border-primary-orange/40 transition duration-200 font-jetbrains"
                            required
                        />
                        <button
                            type="submit"
                            class="w-full sm:w-auto shrink-0 bg-primary-orange text-white text-sm px-4 py-2.5 rounded-lg hover:bg-orange-600 transition-all duration-200 font-jetbrains"
                        >
                            Agregar
                        </button>
                    </div>
                </form>
            </>
        )
    }
</div>
<script>
    import { getExerciseDownload } from "../data";
    import { dispatchApiError } from "../../../lib/events";

    const downloadButton = document.querySelector("[data-exercise-download]") as HTMLButtonElement | null;
    const spinner = document.querySelector("[data-exercise-spinner]") as SVGElement | null;
    const buttonText = document.querySelector("[data-exercise-text]") as HTMLSpanElement | null;

    const toggleLoading = (isLoading: boolean) => {
        if (!downloadButton || !spinner || !buttonText) return;
        downloadButton.disabled = isLoading;
        spinner.classList.toggle("hidden", !isLoading);
        buttonText.textContent = isLoading ? "Descargando..." : "Descargar";
    };

    const downloadFile = (blob: Blob, filename: string) => {
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement("a");
        anchor.href = url;
        anchor.download = filename;
        anchor.click();
        URL.revokeObjectURL(url);
    };

    downloadButton?.addEventListener("click", async () => {
        try {
            toggleLoading(true);
            const payload = await getExerciseDownload();
            const fileResponse = await fetch(payload.url, { method: "GET" });

            if (!fileResponse.ok) {
                throw new Error("No se pudo descargar el PDF");
            }

            const blob = await fileResponse.blob();
            downloadFile(blob, payload.filename ?? "ejercicio.pdf");
        } catch (error) {
            const message = error instanceof Error ? error.message : "Error al descargar el ejercicio";
            dispatchApiError(message);
        } finally {
            toggleLoading(false);
        }
    });

    const submitButton = document.getElementById("form-repo") as HTMLFormElement;

    submitButton.addEventListener("submit", (e) => {
        e.preventDefault();
        const input = document.getElementById("repo-url") as HTMLInputElement;
        const repoUrl = input.value.trim();
        if (repoUrl) {
            console.log("Repositorio agregado:", repoUrl);
            input.value = "";
        }
    });
</script>
