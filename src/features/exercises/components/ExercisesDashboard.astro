---
import ExercisesDownloadCard from "./ExercisesDownloadCard.astro";
---

<section class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-3 py-6 sm:px-4 md:gap-5 md:px-6 md:py-8 lg:px-8">
    <div class="flex min-w-0 flex-1 flex-col gap-4 rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_top,rgba(24,34,66,0.95),rgba(11,16,32,0.98)_55%)] p-4 shadow-[0_20px_80px_rgba(0,0,0,0.35)] sm:p-5 md:gap-5 md:p-6">
        <!-- Header -->
        <header class="flex flex-col gap-2">
            <h2 class="text-2xl text-white sm:text-3xl font-zen-dots">
                <span class="text-primary-orange">$</span>{"Panel de Ejercicios"}<span class="text-primary-orange">.</span>
            </h2>
            <p class="max-w-2xl text-sm text-white/50 font-jetbrains">
                <span class="text-primary-orange">{"// "}</span>Descarga de materiales y entrega de solución
            </p>
        </header>

        <!-- Download Cards -->
        <div class="flex flex-col gap-4 md:gap-5">
            <div>
                <h3 class="text-lg text-white font-zen-dots mb-3">
                    <span class="text-primary-orange">~</span> Materiales
                </h3>
                <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
                    <ExercisesDownloadCard
                        isPDF={true}
                        text="Instrucciones Completas"
                        description="Documento PDF con las instrucciones detalladas del ejercicio"
                    />
                    <ExercisesDownloadCard
                        isPDF={false}
                        text="Información Básica"
                        description="Resumen general con los puntos clave del ejercicio"
                    />
                </div>
            </div>

            <!-- Submit Solution -->
            <div>
                <h3 class="text-lg text-white font-zen-dots mb-3">
                    <span class="text-primary-orange">~</span> Entregar Solución
                </h3>
                <ExercisesDownloadCard
                    isPDF={false}
                    mode="add"
                    text="Agregar Ejercicio"
                    description="Ingrese la URL del repositorio"
                />
            </div>
        </div>
    </div>
</section>
