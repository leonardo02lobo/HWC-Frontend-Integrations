<section
    class="w-full flex md:flex-row flex-col-reverse justify-center items-center gap-6 bg-transparent px-6 md:px-20 py-12 min-h-[70vh]"
    id="main"
>
    <div
        class="flex flex-col justify-center items-center md:items-start gap-6 flex-1"
    >
        <h1
            class="xl:text-5xl lg:text-3xl md:text-2xl text-xl flex flex-col justify-start items-center md:items-start gap-2 text-white"
            id="hero-title"
        >
            <div class="flex flex-row underline decoration-white text-center md:text-left">
                <p class="text-primary-orange">&lt;</p>
                <p id="type-line-1" class="whitespace-nowrap"></p>
            </div>
            <div class="flex flex-row underline decoration-primary-orange invisible" id="type-line-2-wrapper">
                <p id="type-line-2"></p>
                <p class="text-primary-orange">/&gt;</p>
            </div>
        </h1>
        <script>
            const line1 = "HELLO WORLD CUP";
            const line2 = "2026";
            const el1 = document.getElementById("type-line-1")!;
            const el2 = document.getElementById("type-line-2")!;
            const wrapper2 = document.getElementById("type-line-2-wrapper")!;

            let i = 0;
            el1.classList.add("border-r-2", "border-primary-orange");

            function typeLine1() {
                if (i < line1.length) {
                    el1.textContent += line1[i];
                    i++;
                    setTimeout(typeLine1, 100);
                } else {
                    el1.classList.remove("border-r-2", "border-primary-orange");
                    wrapper2.classList.remove("invisible");
                    el2.classList.add("border-r-2", "border-primary-orange");
                    i = 0;
                    setTimeout(typeLine2, 200);
                }
            }

            function typeLine2() {
                if (i < line2.length) {
                    el2.textContent += line2[i];
                    i++;
                    setTimeout(typeLine2, 100);
                } else {
                    setTimeout(() => {
                        el2.classList.remove("border-r-2", "border-primary-orange");
                    }, 1000);
                }
            }

            typeLine1();
        </script>
        <strong class="text-primary-orange w-full text-center md:text-left text-lg md:text-2xl font-jetbrains">
            14 DE JUNIO, 2026 &bull; Táchira &bull; San Cristobal
        </strong>
        <div class="w-full max-w-lg text-center md:text-left text-white text-sm md:text-base leading-relaxed">
            <p>
                Bienvenido a la competencia de programación creada por
                estudiantes y hecha para estudiantes<span class="text-primary-orange">.</span>
            </p>
            <p class="mt-2">
                Únete a nuestra competencia para que pruebes todos tus
                conocimientos y seas parte de la familia <span class="text-primary-orange font-zen-dots">HELLO WORLD CUP.</span>
            </p>
        </div>
        <a href="/register" class="bg-primary-orange text-white px-6 py-3 rounded-lg transition-all duration-300 hover:scale-102 cursor-pointer animate-glow-pulse font-semibold text-sm tracking-wide">
            Unirme a la comunidad
        </a>
    </div>
    <div class="flex justify-center items-center flex-1 max-w-md md:max-w-lg">
        <img
            src="/assets/mascot/logo-hwc-2026.png"
            alt="Hello World Cup 2026 mascot"
            class="w-full h-auto object-contain"
        />
    </div>
</section>
