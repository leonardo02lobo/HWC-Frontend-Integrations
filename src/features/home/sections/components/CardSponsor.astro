---
interface Props {
    name: string;
    description: string;
    logo: string;
    noBackground?: boolean;
}
const { name, description, logo, noBackground = false } = Astro.props as Props;

const baseClasses = "flex flex-col justify-center items-center gap-4 p-6 transition-all duration-300 hover:-translate-y-1 rounded-2xl";
const bgClasses = noBackground ? "" : " bg-[#141929] border border-gray-800/60 hover:border-gray-700/80";
const classes = `${baseClasses}${bgClasses}`.trim();
---

<div class={classes}>
    <div class="w-full max-w-xs sm:max-w-sm md:max-w-md">
        <img src={logo} alt={name} class="w-full h-auto" />
    </div>
    <div class="flex flex-col gap-2 text-center justify-center items-center">
        <h3 class="flex flex-row gap-3 text-white text-lg md:text-xl font-bold">
            <p class="text-primary-orange">&lt;</p>
            <p>{name}</p>
            <p class="text-primary-orange">/&gt;</p>
        </h3>
        <span class="text-center text-white text-sm md:text-base">{description}</span>
    </div>
</div>