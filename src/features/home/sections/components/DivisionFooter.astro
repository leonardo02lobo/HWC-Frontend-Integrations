---
interface Props {
    rotate: boolean;
}
const { rotate } = Astro.props;
---

<div class="flex items-center gap-4 w-full px-6 md:px-20">
    <div class={`h-px flex-1 ${rotate ? 'bg-gradient-to-r from-transparent via-primary-orange/40 to-primary-orange' : 'bg-gradient-to-r from-transparent via-gray-600/40 to-gray-500'}`} />
    <span class="text-white text-2xl md:text-4xl font-zen-dots whitespace-nowrap">
        <span class="text-primary-orange">&lt;</span>{rotate ? (
            <>EQUIPO H<span class="text-primary-orange">W</span>C</>
        ) : (
            <>H<span class="text-primary-orange">W</span>C</>
        )}<span class="text-primary-orange">&nbsp;/&gt;</span>
    </span>
    <div class={`h-px flex-1 ${rotate ? 'bg-gradient-to-l from-transparent via-gray-600/40 to-gray-500' : 'bg-gradient-to-l from-transparent via-primary-orange/40 to-primary-orange'}`} />
</div>
