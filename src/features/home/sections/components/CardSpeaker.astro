---
import { Image } from "astro:assets";

interface Props {
    name: string;
    role: string;
    company: string;
    avatar: any;
    tittle: string;
    github: string;
    linkedin: string;
    instagram: string;
    bio: string;
}
const {
    name,
    role,
    company,
    avatar,
    tittle,
    github,
    linkedin,
    instagram,
    bio,
} = Astro.props as Props;
---

<div
    class="flex flex-col transition-all duration-300 hover:scale-105 hover:-translate-y-2 hover:shadow-2xl md:flex-row gap-8 p-8 w-full border border-gray-800 rounded-2xl bg-gray-900/40 shadow-lg"
>
    <div
        class="flex flex-col items-center flex-shrink-0 w-full md:w-1/3 lg:w-1/4 h-64 md:h-auto overflow-hidden rounded-2xl shadow-md relative"
    >
        <Image
            src={avatar}
            alt={name}
            class="absolute inset-0 w-full h-full object-cover"
        />
    </div>

    <div
        class="flex flex-col flex-1 gap-4 mt-4 md:mt-2 pt-4 md:pt-0 md:pl-8 md:border-l md:border-gray-800"
    >
        <h4
            class="font-zen-dots text-2xl md:text-3xl font-bold text-primary-orange text-center md:text-left mb-2"
        >
            {tittle}
        </h4>

        <div
            class="prose prose-invert text-white prose-p:text-white prose-headings:text-white max-w-none text-justify md:text-left"
        >
            <slot />
        </div>

        <hr class="border-gray-800 my-2 w-full mx-auto" />

        <div class="text-center md:text-left flex flex-col gap-1 w-full">
            <h3
                class="flex flex-row gap-2 justify-center md:justify-start text-white text-2xl font-bold"
            >
                <span class="text-primary-orange">&lt;</span>
                <span>{name}</span>
                <span class="text-primary-orange">/&gt;</span>
            </h3>
            <p class="text-gray-300 font-semibold">
                {role} @ <span class="text-primary-orange">{company}</span>
            </p>
        </div>

        <p class="text-gray-400 text-sm text-center md:text-left italic">
            {bio}
        </p>

        <div class="flex flex-wrap justify-center md:justify-start gap-4 mt-2">
            {
                github && (
                    <a
                        href={`https://${github}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-semibold text-gray-400 hover:text-purple-700 transition hover:scale-110"
                    >
                        GitHub
                    </a>
                )
            }
            {
                linkedin && (
                    <a
                        href={`https://${linkedin}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-semibold text-gray-400 hover:text-blue-600 transition hover:scale-110"
                    >
                        LinkedIn
                    </a>
                )
            }
            {
                instagram && (
                    <a
                        href={`https://${instagram}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-semibold text-gray-400 hover:text-pink-500 transition hover:scale-110"
                    >
                        Instagram
                    </a>
                )
            }
        </div>
    </div>
</div>
