---
import Instagram from "../../../components/ui/Instagram.astro";
import DivisionFooter from "./components/DivisionFooter.astro";
---

<div class="flex flex-col justify-center items-center gap-10 w-full animate-on-scroll">
    <DivisionFooter rotate={true} />
    <div class="flex flex-col md:flex-row justify-center items-center gap-10 md:gap-16 w-full px-6 md:px-20">
        <div class="flex justify-center items-center md:w-1/2">
            <img src="/assets/team/Green-Team-de-james-gosling.png" alt="Green Team led by James Gosling" class="w-full h-60 md:h-96 object-cover rounded-2xl border border-gray-800/60"/>
        </div>
        <div
            class="flex flex-col justify-center items-center md:items-start md:w-1/2 gap-6 text-white text-center md:text-left"
        >
            <h3 class="text-2xl md:text-3xl font-zen-dots">
                <span class="text-primary-orange">&lt;</span>Equipo HWC<span class="text-primary-orange">&nbsp;/&gt;</span>
            </h3>
            <p class="text-gray-300 leading-relaxed">
                Lorem ipsum dolor sit amet consectetur adipisicing elit.
                Obcaecati magni laboriosam cumque culpa consequuntur?
                Repellendus dolore dolorum accusantium quis magni? Est neque
                voluptas eum ipsum quidem excepturi, iusto quisquam? Delectus.
            </p>
            <a href="https://www.instagram.com/helloworldcup_/" target="_blank" class="flex flex-row items-center gap-3 text-gray-400 hover:text-primary-orange transition-colors">
                <Instagram />
                <span class="font-jetbrains text-sm">@HelloWorldCup</span>
            </a>
        </div>
    </div>
</div>
