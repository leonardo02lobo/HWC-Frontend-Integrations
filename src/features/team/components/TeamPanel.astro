---
import {
	apiFlow,
	invitationsReceived,
	selectedTeamId,
	selectedTeamMembersOverflow,
	selectedTeamMembersPreview,
	teams,
} from "../data";
import TeamsTable from "./TeamsTable.astro";
import TeamDetailPanel from "./TeamDetailPanel.astro";
import TeamDetailModal from "./TeamDetailModal";
import TeamCreateModal from "./TeamCreateModal";

// Toggle this when wiring real auth: true when the user already belongs to a team.
const hasTeam = false;

const selectedTeam = teams.find((t) => t.id === selectedTeamId) ?? teams[0];

const methodColor: Record<string, string> = {
	GET: "text-emerald-300",
	POST: "text-primary-orange",
	PATCH: "text-amber-300",
	DELETE: "text-rose-300",
};
---

<section class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-3 py-6 sm:px-4 md:gap-5 md:px-6 md:py-8 lg:px-8">
	<div class="flex min-w-0 flex-col gap-5 rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_top,rgba(24,34,66,0.95),rgba(11,16,32,0.98)_55%)] p-4 shadow-[0_20px_80px_rgba(0,0,0,0.35)] sm:p-5 md:p-6">
		<!-- Page header -->
		<header class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
			<div class="flex flex-col gap-2">
				<h1 class="text-2xl text-white sm:text-3xl font-zen-dots">
					<span class="text-primary-orange">$</span>{"Gestión de Equipo"}<span class="text-primary-orange">.</span>
				</h1>
				<p class="text-sm text-white/50 font-jetbrains">
					<span class="text-primary-orange">{"// "}</span>Gestiona colaboradores, invitaciones y accesos
				</p>
			</div>

			<label class="flex w-full items-center gap-2.5 rounded-lg border border-gray-800/60 bg-[rgba(11,16,32,0.6)] px-3.5 py-2.5 lg:w-auto lg:min-w-[20rem]">
				<svg viewBox="0 0 16 16" class="h-3.5 w-3.5 shrink-0 text-white/40" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<circle cx="7" cy="7" r="5" />
					<path d="M11 11l3 3" stroke-linecap="round" />
				</svg>
				<input
					type="search"
					placeholder="Buscar equipo..."
					class="min-w-0 flex-1 bg-transparent text-sm text-white outline-none placeholder:text-white/25 font-jetbrains"
					aria-label="Buscar equipo"
				/>
			</label>
		</header>

		<!-- Table + Detail row -->
		<div class="grid grid-cols-1 gap-4 lg:grid-cols-[minmax(0,1fr)_26rem] md:gap-5">
			<TeamsTable teams={teams} selectedId={selectedTeam.id} />

			<div class="flex flex-col gap-4 md:gap-5">
				{
					hasTeam ? (
						<TeamDetailPanel
							team={selectedTeam}
							membersPreview={selectedTeamMembersPreview}
							membersOverflow={selectedTeamMembersOverflow}
						/>
					) : (
						<aside
							data-team-section="team-detail"
							class="flex flex-col items-center gap-4 rounded-2xl border border-dashed border-gray-800/80 bg-[#141929] p-6 text-center transition-all duration-300 hover:border-gray-700/80"
						>
							<span class="flex h-12 w-12 items-center justify-center rounded-full border border-primary-orange/30 bg-primary-orange/10 text-primary-orange">
								<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
									<circle cx="9" cy="8" r="3.25" />
									<path d="M2.75 19c.5-3 3-5 6.25-5s5.75 2 6.25 5" stroke-linecap="round" />
									<path d="M19 8v6M16 11h6" stroke-linecap="round" />
								</svg>
							</span>
							<div class="flex flex-col gap-1">
								<h3 class="text-base text-white font-zen-dots sm:text-lg">Aún no tienes equipo</h3>
								<p class="max-w-xs text-xs text-white/50 font-jetbrains">
									Crea tu equipo para empezar ó espera la invitación por parte de un equipos.
								</p>
							</div>
							<button
								type="button"
								data-team-create-trigger
								class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary-orange px-4 py-2.5 text-sm text-white transition-all duration-200 hover:bg-orange-600 font-jetbrains"
							>
								<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
									<path d="M8 3v10M3 8h10" stroke-linecap="round" />
								</svg>
								Crear Equipo
							</button>
							<button
								type="button"
								data-team-section-trigger="invitations"
								class="text-xs text-primary-orange transition-colors duration-200 hover:text-orange-400 font-jetbrains underline-offset-4 hover:underline"
							>
								Verificar invitaciones pendientes...
							</button>
						</aside>
					)
				}

				<!-- Flujo rápido -->
				<section class="flex flex-col gap-3 rounded-2xl border border-gray-800/60 bg-[#141929] p-4 transition-colors duration-200 hover:border-gray-700/80 md:p-5">
					<header class="flex flex-col gap-1">
						<h2 class="text-base text-white font-zen-dots">
							<span class="text-primary-orange">~</span> Flujo rápido
						</h2>
						<p class="text-xs text-white/40 font-jetbrains">
							<span class="text-primary-orange">{"// "}</span>Pulsa un paso para resaltar la zona correspondiente
						</p>
					</header>

					<ol class="flex flex-col gap-1.5">
						{
							apiFlow.map((step) => (
								<li>
									<button
										type="button"
										data-team-section-trigger={step.target}
										class="group flex w-full items-start gap-2.5 rounded-lg border border-transparent px-2 py-1.5 text-left text-xs font-jetbrains leading-relaxed transition-all duration-200 hover:border-primary-orange/30 hover:bg-primary-orange/[0.06] focus-visible:border-primary-orange/40 focus-visible:bg-primary-orange/[0.08] focus-visible:outline-none"
									>
										<span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-md bg-primary-orange/10 text-[10px] text-primary-orange transition-colors duration-200 group-hover:bg-primary-orange/20">
											{step.n}
										</span>
										<span class="min-w-0 flex-1 text-white/60 transition-colors duration-200 group-hover:text-white/80">
											{step.label}{" "}
											<code class={`${methodColor[step.method]} font-jetbrains`}>{step.method}</code>{" "}
											<code class="text-white/80">{step.path}</code>
										</span>
										<svg
											viewBox="0 0 16 16"
											class="mt-1 h-3 w-3 shrink-0 text-white/20 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-primary-orange"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											aria-hidden="true"
										>
											<path d="M6 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</button>
								</li>
							))
						}
					</ol>
				</section>
			</div>
		</div>

		<!-- Invitaciones recibidas (full width) -->
		<section
			id="invitations-card"
			data-team-section="invitations"
			class="flex flex-col gap-3 rounded-2xl border border-gray-800/60 bg-[#141929] p-4 transition-all duration-300 hover:border-gray-700/80 md:p-5"
		>
			<header class="flex flex-col gap-1">
				<h2 class="text-base text-white font-zen-dots">
					<span class="text-primary-orange">~</span> Invitaciones recibidas
				</h2>
				<p class="text-xs text-white/40 font-jetbrains">
					<span class="text-primary-orange">{"// "}</span>Gestiona las invitaciones que has recibido
				</p>
			</header>

				<div class="overflow-x-auto">
					<table class="w-full min-w-[420px] border-separate border-spacing-0" aria-label="Invitaciones recibidas">
						<thead>
							<tr>
								{
									["Equipo", "Invitado por", "Fecha", "Estado", "Acciones"].map((h) => (
										<th class="border-b border-gray-800/60 px-2 py-2 text-left text-[10px] uppercase tracking-wider text-white/40 font-jetbrains">
											{h}
										</th>
									))
								}
							</tr>
						</thead>
						<tbody>
							{
								invitationsReceived.map((inv) => (
									<tr class="transition-colors duration-150 hover:bg-white/[0.02]">
										<td class="border-b border-gray-800/40 px-2 py-3 align-middle">
											<div class="flex items-center gap-2">
												<span
													class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border bg-white/5 text-[9px] font-zen-dots"
													style={`border-color:${inv.team.accent}; color:${inv.team.accent}`}
													aria-hidden="true"
												>
													{inv.team.initials}
												</span>
												<span class="text-xs text-white font-jetbrains whitespace-nowrap">{inv.team.name}</span>
											</div>
										</td>
										<td class="border-b border-gray-800/40 px-2 py-3 align-middle">
											<span class="text-xs text-white/70 font-jetbrains whitespace-nowrap">{inv.invitedBy}</span>
										</td>
										<td class="border-b border-gray-800/40 px-2 py-3 align-middle">
											<span class="text-xs text-white/50 font-jetbrains whitespace-nowrap">{inv.date}</span>
										</td>
										<td class="border-b border-gray-800/40 px-2 py-3 align-middle">
											<span class="inline-flex rounded-md border border-primary-orange/40 bg-primary-orange/10 px-1.5 py-0.5 text-[10px] text-primary-orange font-jetbrains">
												{inv.status}
											</span>
										</td>
										<td class="border-b border-gray-800/40 px-2 py-3 align-middle">
											<div class="flex items-center gap-1">
												<button
													type="button"
													aria-label={`Aceptar invitación de ${inv.team.name}`}
													class="inline-flex h-6 w-6 items-center justify-center rounded-md border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 transition-colors duration-150 hover:bg-emerald-500/15"
												>
													<svg viewBox="0 0 16 16" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2.5">
														<path d="M3 8.5l3.5 3.5L13 4.5" stroke-linecap="round" stroke-linejoin="round" />
													</svg>
												</button>
												<button
													type="button"
													aria-label={`Rechazar invitación de ${inv.team.name}`}
													class="inline-flex h-6 w-6 items-center justify-center rounded-md border border-rose-500/30 bg-rose-500/10 text-rose-300 transition-colors duration-150 hover:bg-rose-500/15"
												>
													<svg viewBox="0 0 16 16" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2.5">
														<path d="M3 3l10 10M13 3L3 13" stroke-linecap="round" />
													</svg>
												</button>
											</div>
										</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>

			<p class="text-xs text-white/40 font-jetbrains">
				Mostrando <span class="text-white/70">1</span> a <span class="text-white/70">{invitationsReceived.length}</span> de <span class="text-white/70">{invitationsReceived.length}</span> invitaciones
			</p>
		</section>
	</div>

	<TeamDetailModal teams={teams} client:load />
	<TeamCreateModal client:load />
</section>

<script>
	const dispatchDetail = (teamId: string) => {
		window.dispatchEvent(new CustomEvent("team:open-detail", { detail: { teamId } }));
	};

	const dispatchCreate = () => {
		window.dispatchEvent(new CustomEvent("team:open-create"));
	};

	document.addEventListener("click", (event) => {
		const target = event.target as HTMLElement | null;
		if (!target) return;

		const detailTrigger = target.closest<HTMLElement>("[data-team-detail-trigger]");
		if (detailTrigger) {
			event.preventDefault();
			const teamId = detailTrigger.getAttribute("data-team-detail-trigger");
			if (teamId) dispatchDetail(teamId);
			return;
		}

		const createTrigger = target.closest<HTMLElement>("[data-team-create-trigger]");
		if (createTrigger) {
			event.preventDefault();
			dispatchCreate();
			return;
		}

		const sectionTrigger = target.closest<HTMLElement>("[data-team-section-trigger]");
		if (sectionTrigger) {
			event.preventDefault();
			const sectionName = sectionTrigger.getAttribute("data-team-section-trigger");
			if (!sectionName) return;
			const section = document.querySelector<HTMLElement>(`[data-team-section="${sectionName}"]`);
			if (!section) return;
			section.scrollIntoView({ behavior: "smooth", block: "center" });
			section.classList.remove("team-section--highlight");
			void section.offsetWidth;
			section.classList.add("team-section--highlight");
			window.setTimeout(() => {
				section.classList.remove("team-section--highlight");
			}, 1800);
		}
	});
</script>

<style is:global>
	.team-section--highlight {
		border-color: rgba(255, 77, 0, 0.7);
		box-shadow: 0 0 0 2px rgba(255, 77, 0, 0.25), 0 18px 50px rgba(255, 77, 0, 0.18);
		animation: team-section-pulse 1.8s ease-out;
	}

	@keyframes team-section-pulse {
		0% {
			box-shadow: 0 0 0 0 rgba(255, 77, 0, 0.55);
		}
		70% {
			box-shadow: 0 0 0 14px rgba(255, 77, 0, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(255, 77, 0, 0);
		}
	}
</style>
