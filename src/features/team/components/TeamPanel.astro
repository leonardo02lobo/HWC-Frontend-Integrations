---
import { members } from "../data";
import TeamMemberCard from "./TeamMemberCard.astro";
import TeamToolbar from "./TeamToolbar.astro";
import ParticipantSidebar from "../../shared/components/ParticipantSidebar.astro";

const navigation = [
	{ label: "Ejercicios", href: "/exercises" },
	{ label: "Mi Equipo", href: "/team", active: true },
	{ label: "Perfil", href: "/profile" },
	{ label: "Status", href: "/tableDashboard" },
];
---

<section class="mx-auto flex min-h-[calc(100vh-2rem)] w-full max-w-7xl flex-col gap-4 px-3 py-3 sm:px-4 md:gap-5 md:px-6 lg:flex-row lg:px-8">
	<div class="lg:sticky lg:top-4 lg:h-[calc(100vh-2rem)] lg:w-[20rem] lg:shrink-0">
		<ParticipantSidebar items={navigation} />
	</div>

	<div class="flex min-w-0 flex-1 flex-col gap-4 rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_top,rgba(24,34,66,0.95),rgba(11,16,32,0.98)_55%)] p-4 shadow-[0_20px_80px_rgba(0,0,0,0.35)] sm:p-5 md:gap-5 md:p-6">
		<!-- Header -->
		<header class="flex flex-col gap-2">
			<h2 class="text-2xl text-white sm:text-3xl font-zen-dots">
				<span class="text-primary-orange">$</span>{"Gestión de Equipo"}<span class="text-primary-orange">.</span>
			</h2>
			<p class="max-w-2xl text-sm text-white/50 font-jetbrains">
				<span class="text-primary-orange">{"// "}</span>Gestiona colaboradores, invitaciones y accesos
			</p>
		</header>

		<!-- Toolbar -->
		<TeamToolbar />

		<!-- Members list -->
		<div class="flex flex-col gap-4">
			<h3 class="text-lg text-white font-zen-dots">
				<span class="text-primary-orange">~</span> Miembros
			</h3>
			<div class="flex flex-col gap-3">
				{members.map((member) => <TeamMemberCard member={member} />)}
			</div>
		</div>
	</div>
</section>
