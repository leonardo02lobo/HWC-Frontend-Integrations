---
import type { MemberAvatar, Team } from "../data";

interface Props {
	team: Team;
	membersPreview: MemberAvatar[];
	membersOverflow: number;
}

const { team, membersPreview, membersOverflow } = Astro.props as Props;
---

<aside
	data-team-section="team-detail"
	class="flex flex-col gap-5 rounded-2xl border border-gray-800/60 bg-[#141929] p-4 transition-all duration-300 hover:border-gray-700/80 md:p-5"
>
	<!-- Header -->
	<header class="flex items-start justify-between gap-3">
		<div class="flex min-w-0 flex-1 items-center gap-3">
			<span
				class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border bg-white/5 text-xs font-zen-dots"
				style={`border-color:${team.accent}; color:${team.accent}`}
				aria-hidden="true"
			>
				{team.initials}
			</span>
			<div class="flex min-w-0 flex-col gap-1">
				<div class="flex flex-wrap items-center gap-2">
					<h3 class="text-base text-white font-zen-dots whitespace-nowrap sm:text-lg">{team.name}</h3>
					<span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-2 py-0.5 text-[11px] text-emerald-300 font-jetbrains">
						<span class="relative inline-flex h-1.5 w-1.5">
							<span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-60"></span>
							<span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
						</span>
						{team.status}
					</span>
				</div>
				<p class="text-xs text-white/50 font-jetbrains">{team.description}</p>
			</div>
		</div>
		<button
			type="button"
			data-team-detail-trigger={team.id}
			class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-gray-800/60 px-3 py-1.5 text-xs text-white/70 transition-colors duration-200 hover:border-gray-700/80 hover:text-white font-jetbrains"
		>
			<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
				<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z" />
				<circle cx="12" cy="12" r="3" />
			</svg>
			Ver detalle
		</button>
	</header>

	<!-- Repositorio (texto) -->
	<div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs font-jetbrains">
		<span class="text-white/40">Repositorio:</span>
		<a
			href={team.repository.href}
			target="_blank"
			rel="noreferrer"
			class="inline-flex items-center gap-1 text-primary-orange hover:text-orange-400 transition-colors duration-200 break-all"
		>
			{team.repository.label}
			<svg viewBox="0 0 16 16" class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M6 3h7v7M13 3L7 9M11 9v4H3V5h4" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</a>
	</div>

	<!-- Miembros -->
	<div class="flex flex-col gap-2.5">
		<div class="flex items-center justify-between">
			<h4 class="text-sm text-white font-zen-dots">
				Miembros <span class="text-white/40 font-jetbrains">({team.memberCount})</span>
			</h4>
			<button
				type="button"
				class="text-xs text-primary-orange hover:text-orange-400 transition-colors duration-200 font-jetbrains"
			>
				Ver todos los miembros
			</button>
		</div>
		<div class="flex items-center -space-x-2">
			{
				membersPreview.map((m) => (
					<img
						src={m.photo}
						alt=""
						loading="lazy"
						class="h-8 w-8 rounded-full border-2 border-[#141929] object-cover bg-white/5"
					/>
				))
			}
			{membersOverflow > 0 && (
				<span class="ml-1 inline-flex h-8 min-w-8 items-center justify-center rounded-full border border-gray-800/80 bg-[rgba(11,16,32,0.8)] px-1.5 text-[10px] text-white/70 font-jetbrains">
					+{membersOverflow}
				</span>
			)}
		</div>
	</div>
</aside>
