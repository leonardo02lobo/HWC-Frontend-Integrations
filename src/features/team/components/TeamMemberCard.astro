---
import type { TeamMember } from "../data";

interface Props {
	member: TeamMember;
}

const { member } = Astro.props as Props;
---

<article class="flex flex-col gap-4 rounded-3xl border border-white/10 bg-[linear-gradient(180deg,rgba(18,27,50,0.95),rgba(10,15,29,0.98))] p-4 shadow-[0_18px_50px_rgba(0,0,0,0.25)] sm:flex-row sm:items-center sm:gap-5 md:p-5" aria-label={`Miembro del equipo: ${member.name}`}>
	<div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full border-4 border-(--accent) bg-white/10 text-2xl font-zen-dots text-white shadow-[0_0_0_6px_rgba(255,255,255,0.04)]" style={`--accent:${member.accent ?? "#FF4D00"}`}>
		<span>{member.initials}</span>
	</div>

	<div class="flex flex-1 flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
		<div class="flex flex-col gap-1">
			<h3 class="text-xl text-white md:text-2xl">{member.name}</h3>
			<p class="text-sm text-primary-orange transition hover:text-[#ff8a57]">@{member.username}</p>
			<p class="text-sm text-white/85">{member.role}</p>
		</div>

		<div class="flex flex-col gap-2 sm:items-end">
			<span class="text-sm text-white/60 sm:text-right">{member.status}</span>
			{member.actions?.map((action) => (
				<a href={action.href ?? ""} class:list={{
					"text-sm text-white/60 sm:text-right": true,
					"font-semibold": action.variant === "primary",
				}}>
					[ {action.title} ]
				</a>
			))}
		</div>
	</div>
</article>
