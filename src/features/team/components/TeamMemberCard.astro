---
import type { TeamMember } from "../data";

interface Props {
	member: TeamMember;
}

const { member } = Astro.props as Props;
---

<article
	class="flex flex-col gap-4 bg-[#141929] border border-gray-800/60 rounded-2xl p-4 md:p-5 transition-all duration-300 hover:border-gray-700/80 sm:flex-row sm:items-center sm:gap-5"
	aria-label={`Miembro del equipo: ${member.name}`}
>
	<div
		class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border-2 bg-white/5 text-lg font-zen-dots text-white"
		style={`border-color:${member.accent ?? "#FF4D00"}`}
	>
		<span>{member.initials}</span>
	</div>

	<div class="flex flex-1 flex-col gap-4 sm:flex-row sm:items-center sm:justify-between min-w-0">
		<div class="flex flex-col gap-0.5">
			<h3 class="text-base md:text-lg text-white font-jetbrains">{member.name}</h3>
			<p class="text-sm text-primary-orange font-jetbrains">@{member.username}</p>
			<p class="text-sm text-white/50 font-jetbrains">{member.role}</p>
		</div>

		<div class="flex flex-col gap-1.5 sm:items-end shrink-0">
			<span class="text-xs text-white/40 font-jetbrains sm:text-right">{member.status}</span>
			{member.actions?.map((action) => (
				<a
					href={action.href ?? ""}
					class:list={[
						"text-sm font-jetbrains transition-colors duration-200",
						action.variant === "primary"
							? "text-primary-orange hover:text-orange-400"
							: "text-white/50 hover:text-white/70",
					]}
				>
					{action.title}
				</a>
			))}
		</div>
	</div>
</article>
