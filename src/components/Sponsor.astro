---
import sponsors from "../data/Sponsor.json";
import CardSponsor from "./icons/CardSponsor.astro";

interface CardSponsorProps {
    name: string;
    description: string;
    logo: string;
}
---

<div class="flex flex-col items-center gap-6 p-0 md:px-20 py-10 relative">
    <div class="absolute top-0 left-0 right-0 flex items-center gap-2 w-full px-4 md:px-0">
        <div class="h-1 flex-1 border-2 border-primary-orange"></div>
        <span class="text-white text-xl md:text-2xl px-3">PATROCINADORES</span>
    </div>
    <div class="flex flex-col md:grid md:grid-cols-3 gap-4 md:gap-6 p-6 w-full">
        {
            sponsors.map((sponsor: CardSponsorProps) => (
                <CardSponsor name={sponsor.name} description={sponsor.description} logo={sponsor.logo} />
            ))
        }
    </div>
</div>
