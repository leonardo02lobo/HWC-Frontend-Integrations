---
import Instagram from "../ui/Instagram.astro";
---

<footer class="w-full bg-primary-ark-blue py-12 px-6 md:px-20 mt-16 border-t border-gray-800/60" id="footer">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-10">
        <!-- Logo and Brand -->
        <div class="flex flex-col items-center md:items-start gap-4">
            <a href="/" class="flex items-center gap-3">
                <img src="/assets/mascot/logo-hwc-2026.png" alt="Hello World Cup 2026 Logo" class="w-16 h-16 object-contain" />
                <h2 class="font-zen-dots text-3xl flex flex-row">
                    <span class="text-white">HWC</span>
                    <span class="text-primary-orange">|2026</span>
                </h2>
            </a>
            <p class="text-white/70 text-sm max-w-xs text-center md:text-left">
                El evento de programación más grande del año. Únete a nosotros y demuestra tus habilidades.
            </p>
        </div>

        <!-- Links -->
        <div class="flex flex-col sm:flex-row gap-8 sm:gap-16 text-center md:text-left">
            <div class="flex flex-col gap-3">
                <h3 class="text-primary-orange font-bold text-lg mb-2">Secciones</h3>
                <a href="/#categorias" class="text-white/80 hover:text-primary-orange transition">Categorías</a>
                <a href="/#charlas" class="text-white/80 hover:text-primary-orange transition">Charlas</a>
            </div>
            <div class="flex flex-col gap-3">
                <h3 class="text-primary-orange font-bold text-lg mb-2">Más Info</h3>
                <a href="/#patrocinadores" class="text-white/80 hover:text-primary-orange transition">Patrocinadores</a>
                <a href="/#equipo" class="text-white/80 hover:text-primary-orange transition flex items-center justify-center md:justify-start gap-1">
                    <span class="text-primary-orange">&lt;</span>
                    Equipo HWC
                    <span class="text-primary-orange">/&gt;</span>
                </a>
            </div>
        </div>

        <!-- Social & Contact -->
        <div class="flex flex-col items-center md:items-start gap-4">
            <h3 class="text-primary-orange font-bold text-lg">Síguenos</h3>
            <a href="https://www.instagram.com/helloworldcup_/" target="_blank" class="flex items-center gap-3 text-white/80 hover:text-primary-orange transition">
                <Instagram />
                <span>@HelloWorldCup</span>
            </a>
        </div>
    </div>

    <!-- Copyright -->
    <div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-white/50 text-sm">
        <p>&copy; 2026 Hello World Cup. Todos los derechos reservados.</p>
        <div class="flex gap-4">
            <a href="#" class="hover:text-white transition">Términos y Condiciones</a>
            <a href="#" class="hover:text-white transition">Privacidad</a>
        </div>
    </div>
</footer>
