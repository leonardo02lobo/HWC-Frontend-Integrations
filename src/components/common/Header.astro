---
const url = Astro.url.pathname;

const participantRoutes = ["/exercises", "/team", "/profile", "/tableDashboard"];
const isParticipantArea = participantRoutes.some((route) => url === route || url.startsWith(`${route}/`));

interface NavLink {
    label: string;
    href: string;
    accentBrackets?: boolean;
}

const participantNav: NavLink[] = [
    { label: "EJERCICIOS", href: "/exercises" },
    { label: "MI EQUIPO", href: "/team" },
    { label: "PERFIL", href: "/profile" },
    { label: "STATUS", href: "/tableDashboard" },
];

const marketingNav: NavLink[] = [
    { label: "CATEGORIAS", href: "/#categorias" },
    { label: "CHARLAS", href: "/#charlas" },
    { label: "PATROCINADORES", href: "/#patrocinadores" },
    { label: "EQUIPO HWC", href: "/#equipo", accentBrackets: true },
];

const navItems = isParticipantArea ? participantNav : marketingNav;

const isActive = (href: string) => {
    if (!href.startsWith("/") || href.startsWith("/#")) return false;
    return url === href || url.startsWith(`${href}/`);
};
---

<header
    class="w-full flex xl:flex-row flex-col gap-2 justify-center items-center px-6 md:px-16 py-4 sticky top-0 z-50 bg-primary-ark-blue/80 backdrop-blur-lg border-b border-gray-800/60"
>
    <div
        class="flex xl:flex-row flex-col gap-4 justify-between items-center w-full px-4"
    >
        <a href="/" class="flex flex-row justify-center items-center">
            <img src="/assets/sponsors/crazy.png" alt="Crazy" class="w-28">
            <span class="font-zen-dots text-4xl flex flex-row text-white pr-5">X</span>

            <h1 class="font-zen-dots text-5xl flex flex-row">
                <span class="text-white">HWC</span>
                <span class="text-primary-orange">|2026</span>
            </h1>
            <span class="font-zen-dots text-4xl flex flex-row text-white pl-5">X</span>
            <img src="/assets/sponsors/crazy.png" alt="Crazy" class="xl:w-28 w-20">
        </a>
        <button
            class="block sm:hidden text-white z-50 p-1"
            id="hamburger"
            onclick="toggleMenu()"
        >
            <span id="hamburger-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </span>
        </button>
        <div
            class="sm:flex sm:flex-row sm:items-center flex-col text-white gap-4 hidden"
            id="menu"
        >
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class:list={[
                            "header-link",
                            item.accentBrackets && "flex flex-row",
                            isActive(item.href) && "header-link--active",
                        ]}
                    >
                        {item.accentBrackets ? (
                            <>
                                <p class="text-primary-orange">&lt;</p>
                                <p>{item.label}</p>
                                <p class="text-primary-orange">/&gt;</p>
                            </>
                        ) : (
                            item.label
                        )}
                    </a>
                ))
            }
        </div>
    </div>
    {
        !isParticipantArea && url !== "/register" && (
            <div
                class="sm:flex flex-row justify-center items-center hidden"
                id="button-container"
            >
                <a
                    href="/register"
                    class="bg-primary-orange text-white px-4 py-2 rounded-lg transition hover:scale-105 inline-block"
                >
                    REGISTRARSE
                </a>
            </div>
        )
    }
    {
        isParticipantArea && (
            <div class="sm:flex flex-row justify-center items-center hidden">
                <button
                    type="button"
                    data-signout-button
                    class="bg-primary-orange text-white px-4 py-2 rounded-lg transition hover:scale-105 inline-block whitespace-nowrap disabled:cursor-not-allowed disabled:opacity-50"
                >
                    CERRAR SESIÓN
                </button>
            </div>
        )
    }
</header>

<div
    id="mobile-menu-overlay"
    class="fixed inset-0 bg-black opacity-75 flex items-start justify-center transition-all duration-300 pointer-events-none -translate-y-full z-40"
>
    <div class="w-full max-w-sm mt-32 mx-4 rounded-lg p-4 flex flex-col gap-4">
        <div
            class="flex flex-col text-white gap-4 w-full justify-center items-center"
            id="mobile-menu"
        >
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class:list={[
                            "header-link",
                            item.accentBrackets && "flex flex-row",
                            isActive(item.href) && "header-link--active",
                        ]}
                    >
                        {item.accentBrackets ? (
                            <>
                                <p class="text-primary-orange">&lt;</p>
                                <p>{item.label}</p>
                                <p class="text-primary-orange">/&gt;</p>
                            </>
                        ) : (
                            item.label
                        )}
                    </a>
                ))
            }
        </div>
        {
            !isParticipantArea && (
                <div class="flex justify-center" id="mobile-button-container">
                    <a
                        href="/register"
                        class="bg-primary-orange text-white px-4 py-2 rounded-lg transition hover:scale-105 inline-block"
                    >
                        REGISTRARSE
                    </a>
                </div>
            )
        }
        {
            isParticipantArea && (
                <div class="flex justify-center">
                    <button
                        type="button"
                        data-signout-button
                        class="bg-primary-orange text-white px-4 py-2 rounded-lg transition hover:scale-105 inline-block disabled:cursor-not-allowed disabled:opacity-50"
                    >
                        CERRAR SESIÓN
                    </button>
                </div>
            )
        }
    </div>
</div>

<script type="text/javascript">
    const hamburgerSvg = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>`;
    const closeSvg = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="6" y1="18" x2="18" y2="6"></line></svg>`;

    function toggleMenu() {
        const overlay = document.getElementById("mobile-menu-overlay");
        const icon = document.getElementById("hamburger-icon");

        if (overlay.classList.contains("opacity-0")) {
            overlay.classList.remove(
                "opacity-0",
                "pointer-events-none",
                "-translate-y-full",
            );
            overlay.classList.add(
                "opacity-100",
                "pointer-events-auto",
                "translate-y-0",
            );
            icon.innerHTML = closeSvg;
        } else {
            overlay.classList.remove(
                "opacity-100",
                "pointer-events-auto",
                "translate-y-0",
            );
            overlay.classList.add(
                "opacity-0",
                "pointer-events-none",
                "-translate-y-full",
            );
            icon.innerHTML = hamburgerSvg;
        }
    }
</script>

<script>
    import { clearAuthSession, signOutUser } from "../../features/auth/services/auth.service";

    const signoutButtons = document.querySelectorAll<HTMLButtonElement>("[data-signout-button]");

    signoutButtons.forEach((button) => {
        button.addEventListener("click", async () => {
            signoutButtons.forEach((btn) => (btn.disabled = true));

            try {
                await signOutUser();
            } catch (error) {
                console.error(error);
            } finally {
                clearAuthSession();
                window.location.href = "/register";
            }
        });
    });
</script>

<style>
    @reference "../../styles/global.css";
    .header-link {
        @apply hover:text-primary-orange transition hover:scale-105;
    }
    .header-link--active {
        @apply text-primary-orange;
    }
</style>
